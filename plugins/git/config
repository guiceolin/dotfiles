[color]
  ui = true

[apply]
  whitespace = nowarn

[core]
  autocrlf = false
  hooksPath = .githooks

[branch]
  autosetupmerge = true

[push]
  default = current

[pull]
  rebase = false

[merge]
  summary = true
  verbosity = 1
  tool = vimdiff

[mergetool]
  prompt = false

[diff]
  mnemonicprefix = true
  algorithm = patience

[rerere]
  enabled = true

[format]
  pretty = format:%C(blue)%ad%Creset %C(yellow)%h%C(green)%d%Creset %C(blue)%s %C(magenta) [%an]%Creset

# Personal identity and tokens should live in ~/.gitconfig.user (not versioned)
# Example ~/.gitconfig.user:
#   [user]
#     name = Your Name
#     email = you@example.com
#     signingkey = KEYID
#   [github]
#     user = youruser
[include]
  path = ~/.gitconfig.user
