# vim:ft=zsh

local plugins_dir=$DOTFILES/plugins
local installed_plugins=$DOTFILES_CONFIG/enabled/

local flag_help flag_verbose
local usage=(
    "dotfiles enable [-h|--help]"
    "dotfiles enable [-v|--verbose] plugin_name"
  )

zmodload zsh/zutil
zparseopts -D -F -K -- \
  {h,-help}=flag_help \
  {v,-verbose}=flag_verbose || return 1

[[ -z "$flag_help" ]] || { print -l $usage && return }

if [ $# -lt 1 ]; then
  print -l $usage
  return 1
fi

local verbose=${#flag_verbose}

_log()  { echo "  $1"; }
_vlog() { [[ $verbose -gt 0 ]] && echo "  $1"; }

### No plugin given
local plugin_name=$1
local plugin_dir=$plugins_dir/$plugin_name
local install_file=$plugin_dir/install.sh
local symlink=$installed_plugins/$plugin_name
local plugin_file=$symlink/$plugin_name.plugin.zsh

if [[ ! -d $plugin_dir ]]; then
  echo "dotfiles: plugin '$plugin_name' not found in $plugins_dir"
  return 1
fi

if [[ -e $symlink ]]; then
  echo "dotfiles: plugin '$plugin_name' is already enabled"
  return 0
fi

echo "Enabling plugin $plugin_name..."

_vlog "creating symlink: $symlink -> $plugin_dir"
ln -s $plugin_dir $symlink
_log "symlink created"

if [[ -e $install_file ]]; then
  _vlog "running install script: $install_file"
  . $install_file
  _log "install script done"
fi

local env_file=$symlink/$plugin_name.env.zsh
if [[ -f $env_file ]]; then
  _vlog "sourcing env: $env_file"
  source $env_file
  _log "env loaded"
fi

if [[ -f $plugin_file ]]; then
  _vlog "sourcing: $plugin_file"
  source $plugin_file
  DOTFILES_LOADED_PLUGINS="${DOTFILES_LOADED_PLUGINS:+$DOTFILES_LOADED_PLUGINS:}$plugin_name"
  _log "plugin loaded"
fi

echo "Done"
