# vim:ft=zsh
autoload -Uz _dotfiles_plugin_enable _dotfiles_remote_install _dotfiles_list _dotfiles_link_to_config

_dotfiles_usage() {
  print -l \
    "Usage: dotfiles [-h] <command> [args]" \
    "" \
    "Commands:" \
    "  list                    List installed and available plugins" \
    "  enable [-v] <name>      Enable a plugin (symlink + install + source)" \
    "  remote <git-url>        Clone an external plugin" \
    "  remote [-l|--list]      List remote plugins" \
    "  remote reload           Re-source cloned plugins in current shell" \
    "  remote sync             Clone missing plugins + reload" \
    "" \
    "Options:" \
    "  -h, --help              Show this help"
}

local flag_help
zparseopts -D -F -K -- {h,-help}=flag_help 2>/dev/null

if [[ -n "$flag_help" ]]; then
  _dotfiles_usage
  return 0
fi

if [[ $# -lt 1 ]]; then
  _dotfiles_usage
  return 1
fi

case "$1" in
  list)
    _dotfiles_list
    ;;
  enable)
    shift
    _dotfiles_plugin_enable $@
    ;;
  remote)
    shift
    _dotfiles_remote_install $@
    ;;
  help)
    _dotfiles_usage
    ;;
  *)
    echo "dotfiles: unknown command '$1'"
    _dotfiles_usage
    return 1
    ;;
esac
